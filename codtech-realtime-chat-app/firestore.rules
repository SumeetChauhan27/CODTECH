rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // ---------- users ----------
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && request.auth.uid == userId;
      allow delete: if false;
    }

    // ---------- rooms ----------
    match /rooms/{roomId} {
      function isRoomMember() {
        let room = get(/databases/(default)/documents/rooms/$(roomId)).data;
        return isSignedIn() && (
          (room.get('createdBy', '') == request.auth.uid) ||
          (request.auth.uid in room.get('members', []))
        );
      }

      function isRoomAdmin() {
        let room = get(/databases/(default)/documents/rooms/$(roomId)).data;
        return isSignedIn() && (
          (room.get('createdBy', '') == request.auth.uid) ||
          (request.auth.uid in room.get('admins', []))
        );
      }

      function isRoomCreator() {
        let room = get(/databases/(default)/documents/rooms/$(roomId)).data;
        return isSignedIn() && room.get('createdBy', '') == request.auth.uid;
      }

      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isRoomMember() || isRoomAdmin();
      allow delete: if isRoomCreator();

      // ---------- messages ----------
      match /messages/{messageId} {
        allow read: if isRoomMember();
        allow create: if isRoomMember() && request.resource.data.uid == request.auth.uid;
        allow update: if isRoomMember() &&
          (resource.data.uid == request.auth.uid ||
           request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['readBy', 'reactions', 'starredBy']) ||
           (isRoomAdmin() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isPinned'])));
        allow delete: if resource.data.uid == request.auth.uid || isRoomAdmin();
      }

      // ---------- typing ----------
      match /typing/{userId} {
        allow read: if isRoomMember();
        allow write: if isRoomMember() && request.auth.uid == userId;
      }
    }

    // ---------- notifications ----------
    match /notifications/{userId}/items/{notifId} {
      allow read, update: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn();
      allow delete: if isSignedIn() && request.auth.uid == userId;
    }
  }
}
